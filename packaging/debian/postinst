#!/bin/sh
# postinst — Debian post-installation script for dax-auth
set -e

DAX_USER="dax-auth"
DAX_GROUP="dax-auth"
INSTALLER="/usr/lib/dax-auth/install.sh"

case "$1" in
    configure)
        if [ -x "${INSTALLER}" ]; then
            "${INSTALLER}"
        else
            echo "dax-auth: installer missing at ${INSTALLER}" >&2
            echo "dax-auth: run the installer manually after fixing package layout" >&2
            exit 1
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
