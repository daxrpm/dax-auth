# =============================================================================
# dax-auth — Rust workspace .gitignore
# =============================================================================

# ── Rust build artifacts ──────────────────────────────────────────────────────
/target/
**/target/

# ── Compiled shared libraries ─────────────────────────────────────────────────
# The PAM module (pam_dax_auth.so) is a build output, not a source artifact
*.so
*.so.*
*.dylib
*.dll

# Object files
*.o
*.a

# ── ONNX model files ──────────────────────────────────────────────────────────
# Models are downloaded separately — see models/README.md
# Run: scripts/download_models.sh
models/*.onnx
models/*.bin
models/*.pt

# ── Secrets and environment ───────────────────────────────────────────────────
# NEVER commit credentials, keys, or environment overrides
.env
.env.*
!.env.example

# ── Editor and IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# JetBrains
.fleet/

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Test coverage and profiling ───────────────────────────────────────────────
lcov.info
*.profraw
*.profdata
tarpaulin-report.html
coverage/

# ── Packaging outputs ─────────────────────────────────────────────────────────
# Built packages — generated by CI, not stored in git
packaging/output/
packaging/*.deb
packaging/*.rpm
packaging/*.tar.gz

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.orig
*.log
